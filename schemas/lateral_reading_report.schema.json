{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/lateral_reading_report.schema.json",
  "title": "Lateral Reading Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["responses"],
  "properties": {
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "citations"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri",
              "pattern": "^https?://"
            }
          }
        }
      }
    }
  }
}

